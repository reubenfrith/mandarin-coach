.env
.venv/
venv/
__pycache__/

# Chainlit boilerplate: ignore translations + cache, but TRACK config.toml
# (it now carries our theme name + custom_css, so it must deploy via git).
.chainlit/*
!.chainlit/config.toml
app/.chainlit/*
!app/.chainlit/config.toml
chainlit.md

# CC-CEDICT dictionary cache (downloaded at runtime)
data/cedict.txt

# Local user account store
user_data/
*.pyc
.chroma/
chroma_db/
*.db
.DS_Store

# Eval scratch (isolated ChromaDB for eval runs)
evals/.eval_chroma/
