# Copy this to .env and fill in your values — never commit .env
# Keep comments on their OWN lines (an inline comment after a value can be
# parsed as part of the value by python-dotenv).

# Required: routes all LLM calls through OpenRouter
OPENROUTER_API_KEY=

# Required for login: a random secret that signs auth tokens.
# Generate one with:  uv run chainlit create-secret   (or any long random string)
CHAINLIT_AUTH_SECRET=

# Optional: OpenAI embeddings baseline. If unset, the app falls back to a
# local embedding model, so the app still runs without this key.
OPENAI_API_KEY=

# Optional: agentic web search tool
TAVILY_API_KEY=

# Optional: LangSmith tracing/monitoring
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
# Trace project name. Defaults to "mandarin-coach" for the app and
# "mandarin-coach-evals" for eval runs, so evaluation traffic stays separate.
# LANGSMITH_PROJECT=mandarin-coach

# Optional reliability tuning (seconds). REQUEST_TIMEOUT caps each LLM call;
# AGENT_TURN_TIMEOUT hard-bounds a whole agent turn before falling back to the
# fast model (deepseek, a reasoning model, occasionally hangs many minutes).
# REQUEST_TIMEOUT=90
# AGENT_TURN_TIMEOUT=180
