# Copy this to .env and fill in your values — never commit .env
# Keep comments on their OWN lines (an inline comment after a value can be
# parsed as part of the value by python-dotenv).

# Required: routes all LLM calls through OpenRouter
OPENROUTER_API_KEY=

# Optional: OpenAI embeddings baseline. If unset, the app falls back to a
# local embedding model, so the app still runs without this key.
OPENAI_API_KEY=

# Optional: agentic web search tool
TAVILY_API_KEY=

# Optional: LangSmith tracing/monitoring
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
